{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["bun-types"],
		"baseUrl": ".",
		"paths": {
			"evy-types": ["../../types/generated/ts"],
			"evy-types/*": ["../../types/generated/ts/*"],
			"evy-types/validators": ["../../types/validators.ts"],
			"evy-types/rpcRequestHelpers": ["../../types/rpcRequestHelpers.ts"]
		}
	},
	"include": ["src/**/*", "e2e/**/*"]
}
