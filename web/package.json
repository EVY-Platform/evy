{
	"name": "evy-web",
	"version": "1.0.0",
	"description": "EVY Web App Builder",
	"license": "GPL-3.0-only",
	"type": "module",
	"scripts": {
		"dev": "bun run dev/server.ts",
		"build": "bun run setup && bun build --target=browser --outdir=dist --entry-naming=[dir]/bundle.js --define:__API_URL__=\"'${API_URL:-ws://localhost:8000}'\" app/main.tsx",
		"start": "bun run dev/server.ts",
		"lint": "bunx biome check .",
		"format": "bunx biome format --write .",
		"setup": "mkdir -p dist/.well-known/appspecific && cp app/index.html dist/ && cp -r app/public/* dist/ && cp app/globals.css dist/ && cp -r app/.well-known/* dist/.well-known/",
		"test": "bunx playwright test tests/",
		"test:e2e": "bunx playwright test --config=playwright.e2e.config.js",
		"test:setup": "bunx playwright install --with-deps",
		"test:ui": "bunx playwright test --ui",
		"test:debug": "bunx playwright test --debug"
	},
	"dependencies": {
		"@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
		"@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
		"@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
		"@atlaskit/primitives": "^18.0.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rpc-websockets": "^9.3.3",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.1",
		"@biomejs/biome": "^2.3.14",
		"@types/bun": "^1.3.8",
		"@types/react": "^19.2.11",
		"@types/react-dom": "^19.2.3"
	}
}
