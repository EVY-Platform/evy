{
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["bun-types"],
		"baseUrl": ".",
		"paths": {
			"evy-types": ["../types/generated/ts"],
			"evy-types/*": ["../types/generated/ts/*"]
		}
	},
	"include": ["app/**/*", "dev/**/*", "tests/**/*"]
}
