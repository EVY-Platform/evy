{
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["bun-types"]
	},
	"include": ["app/**/*", "dev/**/*", "tests/**/*"]
}
