# API Configuration
API_PORT=8000
API_HOST=localhost:$API_PORT
API_URL=ws://$API_HOST

# Marketplace service (internal gRPC; main API proxies non-SDUI marketplace traffic here).
# Every non-evy namespace in NAMESPACE_VALUES must have a matching ${NAMESPACE}_GRPC_URL (host:port, no scheme) or the api fails on first use.
MARKETPLACE_GRPC_PORT=8001
MARKETPLACE_DB_DATABASE=marketplace
MARKETPLACE_GRPC_URL=localhost:$MARKETPLACE_GRPC_PORT

# Web Configuration
WEB_PORT=3000

# Database Configuration
DB_USER=evy
DB_PASS=evy
DB_PORT=5432
DB_DOMAIN=localhost
DB_DATABASE=evy

# Domain Configuration
DOMAIN=localhost
EMAIL=my@email.com

# Traefik Configuration
CERT_RESOLVER=le
TRAEFIK_USER=admin
TRAEFIK_PASSWORD_HASH='my_hash'
