# ===========================================
# Root .env - Used by docker-compose.yml
# ===========================================

# API Configuration
API_PORT=8000

# Web Configuration
WEB_PORT=3000

# Database Configuration
DB_USER=evy
DB_PASS=evy
DB_DATABASE=evy
DB_PORT=5432

# ===========================================
# Production Only (docker-compose.prod.yml)
# ===========================================

# Domain Configuration
DOMAIN=localhost
EMAIL=my@email.com

# Traefik Configuration
CERT_RESOLVER=le
TRAEFIK_USER=admin
TRAEFIK_PASSWORD_HASH='$apr1$...'
