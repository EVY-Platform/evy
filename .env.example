# API Configuration
API_PORT=8000
API_HOST=localhost:$API_PORT
API_URL=ws://$API_HOST

# Marketplace service (internal gRPC; main API forwards marketplace `service` here).
# Docker Compose: use the compose service name so the api container can resolve it (`marketplace`).
# Local processes on the host: use `127.0.0.1`.
MARKETPLACE_GRPC_HOST=marketplace
MARKETPLACE_GRPC_PORT=8001

# Web Configuration
WEB_PORT=3000

# Database Configuration
DB_USER=evy
DB_PASS=evy
DB_PORT=5432
DB_DOMAIN=localhost
DB_EVY_DATABASE=evy
DB_MARKETPLACE_DATABASE=marketplace

# Domain Configuration
DOMAIN=localhost
EMAIL=my@email.com

# Traefik Configuration
CERT_RESOLVER=le
TRAEFIK_USER=admin
TRAEFIK_PASSWORD_HASH='my_hash'
