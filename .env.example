# API Configuration
API_PORT=8000
API_HOST=localhost:$API_PORT
API_URL=ws://$API_HOST

# Marketplace service (internal gRPC; main API proxies non-SDUI marketplace traffic here).
# Every non-evy namespace in NAMESPACE_VALUES must have matching ${NAMESPACE}_GRPC_HOST and ${NAMESPACE}_GRPC_PORT or the api fails on first use.
MARKETPLACE_GRPC_HOST=0.0.0.0
MARKETPLACE_GRPC_PORT=8001
MARKETPLACE_DB_DATABASE=marketplace

# Web Configuration
WEB_PORT=3000

# Database Configuration
DB_USER=evy
DB_PASS=evy
DB_PORT=5432
DB_DOMAIN=localhost
DB_DATABASE=evy

# Domain Configuration
DOMAIN=localhost
EMAIL=my@email.com

# Traefik Configuration
CERT_RESOLVER=le
TRAEFIK_USER=admin
TRAEFIK_PASSWORD_HASH='my_hash'
