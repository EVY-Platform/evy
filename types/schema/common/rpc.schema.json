{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "common/rpc",
	"title": "CommonRPC",
	"description": "Shared RPC request/response definitions",
	"$defs": {
		"DataFilter": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"id": { "type": "string", "format": "uuid" },
				"updatedAfter": { "type": "string", "format": "date-time" }
			}
		},
		"IdFilter": {
			"$ref": "#/$defs/DataFilter"
		}
	}
}
