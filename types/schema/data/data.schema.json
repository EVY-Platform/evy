{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "data",
	"title": "DATA_EVY_Rows",
	"description": "API persistence row types: DATA_EVY_Flow, DATA_EVY_Device, DATA_EVY_Service, etc. Date-time fields use ISO 8601 / RFC 3339 strings (format date-time), not Unix timestamps; Drizzle maps them to Postgres text columns.",
	"oneOf": [
		{
			"$ref": "#/$defs/DATA_EVY_Flow"
		},
		{
			"$ref": "#/$defs/DATA_EVY_Data"
		},
		{
			"$ref": "#/$defs/DATA_EVY_Device"
		},
		{
			"$ref": "#/$defs/DATA_EVY_Service"
		},
		{
			"$ref": "#/$defs/DATA_EVY_Organization"
		},
		{
			"$ref": "#/$defs/DATA_EVY_ServiceProvider"
		}
	],
	"$defs": {
		"DATA_EVY_Flow": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "data", "createdAt", "updatedAt"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"data": {
					"$ref": "../sdui/evy.schema.json"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time"
				}
			}
		},
		"DATA_EVY_Data": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "namespace", "resource", "data", "createdAt", "updatedAt"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"namespace": {
					"type": "string",
					"maxLength": 50
				},
				"resource": {
					"type": "string",
					"maxLength": 50
				},
				"data": {
					"$ref": "../common/json.schema.json#/$defs/JSONValue"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time"
				}
			}
		},
		"OS": {
			"type": "string",
			"enum": ["ios", "android", "Web"]
		},
		"DATA_EVY_Device": {
			"type": "object",
			"additionalProperties": false,
			"required": ["token", "os", "createdAt"],
			"properties": {
				"token": {
					"type": "string",
					"maxLength": 256
				},
				"os": {
					"$ref": "#/$defs/OS"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				}
			}
		},
		"DATA_EVY_Service": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "name", "description", "createdAt", "updatedAt"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"name": {
					"type": "string",
					"maxLength": 50
				},
				"description": {
					"type": "string"
				},
				"sortOrder": {
					"type": "integer"
				},
				"defaultWeightKg": {
					"type": "number"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time"
				}
			}
		},
		"DATA_EVY_Organization": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"name",
				"description",
				"logo",
				"url",
				"supportEmail",
				"createdAt",
				"updatedAt"
			],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"name": {
					"type": "string",
					"maxLength": 100
				},
				"description": {
					"type": "string"
				},
				"logo": {
					"type": "string",
					"format": "uuid"
				},
				"url": {
					"type": "string",
					"maxLength": 50
				},
				"supportEmail": {
					"type": "string",
					"maxLength": 50
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time"
				}
			}
		},
		"DATA_EVY_ServiceProvider": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"fkServiceId",
				"fkOrganizationId",
				"name",
				"description",
				"logo",
				"url",
				"createdAt",
				"updatedAt",
				"retired"
			],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"fkServiceId": {
					"type": "string",
					"format": "uuid"
				},
				"fkOrganizationId": {
					"type": "string",
					"format": "uuid"
				},
				"name": {
					"type": "string",
					"maxLength": 100
				},
				"description": {
					"type": "string"
				},
				"logo": {
					"type": "string",
					"format": "uuid"
				},
				"url": {
					"type": "string",
					"maxLength": 50
				},
				"createdAt": {
					"type": "string",
					"format": "date-time"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time"
				},
				"retired": {
					"type": "boolean",
					"default": false
				}
			}
		}
	}
}
