{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "sdui",
	"title": "UI_Flow",
	"description": "UI types: UI_Flow, UI_Page, UI_Row",
	"type": "object",
	"additionalProperties": false,
	"required": ["id", "name", "pages"],
	"properties": {
		"id": { "type": "string", "format": "uuid" },
		"name": { "type": "string", "minLength": 1 },
		"pages": {
			"type": "array",
			"items": { "$ref": "#/$defs/UI_Page" }
		}
	},
	"$defs": {
		"UI_Page": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "title", "rows"],
			"properties": {
				"id": { "type": "string", "format": "uuid" },
				"title": { "type": "string" },
				"rows": {
					"type": "array",
					"items": { "$ref": "#/$defs/UI_Row" }
				},
				"footer": { "$ref": "#/$defs/UI_Row" }
			}
		},
		"UI_Row": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "type", "view", "source", "actions"],
			"properties": {
				"id": { "type": "string", "format": "uuid" },
				"type": {
					"type": "string",
					"enum": [
						"Button",
						"Calendar",
						"ColumnContainer",
						"Dropdown",
						"Info",
						"InlinePicker",
						"InputList",
						"Input",
						"ListContainer",
						"Search",
						"SelectPhoto",
						"SelectSegmentContainer",
						"SheetContainer",
						"TextAction",
						"TextArea",
						"Text",
						"TextSelect"
					]
				},
				"view": {
					"type": "object",
					"additionalProperties": false,
					"required": ["content"],
					"properties": {
						"content": { "$ref": "#/$defs/UI_RowContent" },
						"max_lines": { "type": "string" }
					}
				},
				"source": { "type": "string" },
				"destination": { "type": "string" },
				"actions": {
					"type": "array",
					"default": [],
					"items": { "$ref": "#/$defs/UI_RowAction" }
				}
			}
		},
		"UI_RowContent": {
			"type": "object",
			"required": ["title"],
			"properties": {
				"title": { "type": "string" },
				"label": { "type": "string" },
				"text": { "type": "string" },
				"value": { "type": "string" },
				"placeholder": { "type": "string" },
				"format": { "type": "string" },
				"child": { "$ref": "#/$defs/UI_Row" },
				"action": { "type": "string" },
				"primary": { "type": "string" },
				"secondary": { "type": "string" },
				"subtitle": { "type": "string" },
				"icon": { "type": "string" },
				"content": { "type": "string" },
				"photos": { "type": "string" },
				"children": {
					"type": "array",
					"items": { "$ref": "#/$defs/UI_Row" }
				},
				"segments": {
					"type": "array",
					"items": { "type": "string" }
				}
			},
			"additionalProperties": false
		},
		"UI_RowAction": {
			"type": "object",
			"additionalProperties": false,
			"required": ["condition", "false", "true"],
			"properties": {
				"condition": { "type": "string" },
				"false": { "type": "string" },
				"true": { "type": "string" }
			}
		}
	}
}
