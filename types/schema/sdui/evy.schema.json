{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "sdui",
	"title": "SDUI_Flow",
	"description": "SDUI types: SDUI_Flow, SDUI_Page, SDUI_Row",
	"type": "object",
	"additionalProperties": false,
	"required": ["id", "name", "type", "data", "pages"],
	"properties": {
		"id": { "type": "string", "format": "uuid" },
		"name": { "type": "string", "minLength": 1 },
		"type": {
			"type": "string",
			"enum": ["create", "read", "update", "delete"]
		},
		"data": { "type": "string" },
		"pages": {
			"type": "array",
			"items": { "$ref": "#/$defs/SDUI_Page" }
		}
	},
	"$defs": {
		"SDUI_Page": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "title", "rows"],
			"properties": {
				"id": { "type": "string", "format": "uuid" },
				"title": { "type": "string" },
				"rows": {
					"type": "array",
					"items": { "$ref": "#/$defs/SDUI_Row" }
				},
				"footer": { "$ref": "#/$defs/SDUI_Row" }
			}
		},
		"SDUI_Row": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "type", "view", "actions"],
			"properties": {
				"id": { "type": "string", "format": "uuid" },
				"type": {
					"type": "string",
					"enum": [
						"Button",
						"Calendar",
						"ColumnContainer",
						"Dropdown",
						"Info",
						"InlinePicker",
						"InputList",
						"Input",
						"ListContainer",
						"Search",
						"SelectPhoto",
						"SelectSegmentContainer",
						"SheetContainer",
						"TextAction",
						"TextArea",
						"Text",
						"TextSelect"
					]
				},
				"view": {
					"type": "object",
					"additionalProperties": false,
					"required": ["content"],
					"properties": {
						"content": { "$ref": "#/$defs/SDUI_RowContent" },
						"data": { "type": "string" },
						"max_lines": { "type": "string" }
					}
				},
				"destination": { "type": "string" },
				"actions": {
					"type": "array",
					"default": [],
					"items": { "$ref": "#/$defs/SDUI_RowAction" }
				}
			}
		},
		"SDUI_RowContent": {
			"type": "object",
			"required": ["title"],
			"properties": {
				"title": { "type": "string" },
				"children": {
					"type": "array",
					"items": { "$ref": "#/$defs/SDUI_Row" }
				},
				"child": { "$ref": "#/$defs/SDUI_Row" },
				"segments": {
					"type": "array",
					"items": { "type": "string" }
				}
			},
			"additionalProperties": false
		},
		"SDUI_RowAction": {
			"type": "object",
			"additionalProperties": false,
			"required": ["condition", "false", "true"],
			"properties": {
				"condition": { "type": "string" },
				"false": { "type": "string" },
				"true": { "type": "string" }
			}
		}
	}
}
