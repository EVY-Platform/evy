{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "get-request",
	"title": "GetRequest",
	"description": "JSON-RPC params for get method",
	"oneOf": [
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["service", "resource"],
			"properties": {
				"service": { "const": "evy" },
				"resource": {
					"type": "string",
					"enum": ["sdui", "devices", "organisations", "services", "providers"]
				},
				"filter": { "$ref": "../common/rpc.schema.json#/$defs/DataFilter" }
			}
		},
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["service", "resource"],
			"properties": {
				"service": { "const": "marketplace" },
				"resource": {
					"type": "string",
					"enum": [
						"selling_reasons",
						"conditions",
						"durations",
						"areas",
						"timeslots",
						"items"
					]
				},
				"filter": { "$ref": "../common/rpc.schema.json#/$defs/DataFilter" }
			}
		}
	]
}
