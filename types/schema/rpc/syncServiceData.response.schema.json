	"type": "object",
	"additionalProperties": false,
	"required": ["data"],
	"properties": {
		"data": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["service", "resource", "value"],
				"properties": {
					"service": { "type": "string" },
					"resource": { "type": "string" },
					"value": {}
				}
			}
		}
	}
}
