{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "upsert-request",
	"title": "UpsertRequest",
	"description": "JSON-RPC params for upsert method",
	"type": "object",
	"additionalProperties": false,
	"required": ["namespace", "resource", "data"],
	"properties": {
		"namespace": { "type": "string", "enum": ["evy", "marketplace"] },
		"resource": {
			"type": "string",
			"enum": [
				"sdui",
				"devices",
				"organisations",
				"services",
				"providers",
				"selling_reasons",
				"conditions",
				"durations",
				"areas",
				"timeslots",
				"items"
			]
		},
		"filter": { "$ref": "../common/rpc.schema.json#/$defs/IdFilter" },
		"data": {
			"type": "object",
			"additionalProperties": {
				"$ref": "../common/json.schema.json#/$defs/JSONValue"
			}
		}
	}
}
