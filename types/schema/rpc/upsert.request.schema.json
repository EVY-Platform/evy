{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "upsert-request",
	"title": "UpsertRequest",
	"description": "JSON-RPC params for upsert method",
	"$defs": {
		"UpsertDataPayload": {
			"type": "object",
			"additionalProperties": {
				"$ref": "../common/json.schema.json#/$defs/JSONValue"
			}
		}
	},
	"oneOf": [
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["service", "resource", "data"],
			"properties": {
				"service": { "const": "evy" },
				"resource": {
					"type": "string",
					"enum": ["sdui", "devices", "organisations", "services", "providers"]
				},
				"filter": { "$ref": "../common/rpc.schema.json#/$defs/DataFilter" },
				"data": { "$ref": "#/$defs/UpsertDataPayload" }
			}
		},
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["service", "resource", "data"],
			"properties": {
				"service": { "const": "marketplace" },
				"resource": {
					"type": "string",
					"enum": [
						"selling_reasons",
						"conditions",
						"durations",
						"areas",
						"timeslots",
						"items"
					]
				},
				"filter": { "$ref": "../common/rpc.schema.json#/$defs/DataFilter" },
				"data": { "$ref": "#/$defs/UpsertDataPayload" }
			}
		}
	]
}
