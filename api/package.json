		"bun-types": "^1.3.6",
		"prisma": "^5.1.1"
	},
	"dependencies": {
		"@prisma/client": "^5.1.1",
		"rpc-websockets": "^7.5.1",
		"uuid": "^9.0.0"
	}
}
