{
	"name": "evy",
	"version": "0.0.1",
	"description": "Evy api",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun run db:migrate && bun src/index.ts",
		"lint": "bunx biome check",
		"db:generate": "bunx prisma generate",
		"db:migrate": "bunx prisma migrate deploy",
		"db:migrate:dev": "bunx prisma migrate dev",
		"db:seed": "bun prisma/seed.ts"
	},
	"prisma": {
		"seed": "bun prisma/seed.ts"
	},
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/node": "^18.11.9",
		"@types/uuid": "^9.0.2",
		"@types/ws": "^8.5.5",
		"bun-types": "^1.3.6",
		"prisma": "^5.1.1"
	},
	"dependencies": {
		"@prisma/client": "^5.1.1",
		"rpc-websockets": "^7.5.1",
		"uuid": "^9.0.0"
	}
}
