{
	"name": "evy",
	"version": "0.0.1",
	"description": "Evy api",
	"license": "GPL-3.0-only",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun --env-file=../.env --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun run db:migrate && bun --env-file=../.env src/index.ts",
		"health": "bun src/readiness.ts",
		"health:seeded": "bun src/readiness.ts --require-seeded",
		"test": "bun --env-file=../.env test src/",
		"test:e2e": "bun --env-file=../.env test e2e/",
		"lint": "bunx biome check",
		"format": "bunx biome format --write .",
		"db:generate": "bun --env-file=../.env drizzle-kit generate",
		"db:migrate": "bun --env-file=../.env drizzle-kit migrate",
		"db:push": "bun --env-file=../.env drizzle-kit push",
		"db:studio": "bun --env-file=../.env drizzle-kit studio"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.4.4",
		"@types/node": "^25.6.0",
		"@types/pluralize": "^0.0.33",
		"@types/uuid": "^11.0.0",
		"@types/ws": "^8.18.1",
		"bun-types": "^1.3.12",
		"drizzle-kit": "^0.31.10"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"drizzle-orm": "^0.45.2",
		"pluralize": "^8.0.0",
		"postgres": "^3.4.9",
		"rpc-websockets": "^9.3.8",
		"uuid": "^13.0.0"
	}
}
