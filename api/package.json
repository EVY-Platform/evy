{
	"name": "evy",
	"version": "0.0.1",
	"description": "Evy api",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"lint": "bunx biome check",
		"prisma_generate": "prisma generate",
		"prisma_migration": "prisma migrate dev",
		"prisma_migrate": "prisma migrate deploy",
		"build": "bun build src/index.ts --outdir dist --target bun",
