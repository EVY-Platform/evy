{
	"name": "evy",
	"version": "0.0.1",
	"description": "Evy api",
	"license": "GPL-3.0-only",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun --env-file=../.env --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun run db:migrate && bun --env-file=../.env src/index.ts",
		"test": "bun --env-file=../.env test src/",
		"test:e2e": "bun --env-file=../.env test e2e/",
		"lint": "bunx biome check",
		"format": "bunx biome format --write .",
		"db:generate": "bun --env-file=../.env bunx drizzle-kit generate",
		"db:migrate": "bun --env-file=../.env bunx drizzle-kit migrate",
		"db:push": "bun --env-file=../.env bunx drizzle-kit push",
		"db:studio": "bun --env-file=../.env bunx drizzle-kit studio"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.3.15",
		"@types/node": "^25.2.0",
		"@types/uuid": "^11.0.0",
		"@types/ws": "^8.18.1",
		"bun-types": "^1.3.8",
		"drizzle-kit": "^0.31.8"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8",
		"rpc-websockets": "^9.3.3",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	}
}
